{
  "name": "unified-property-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "npx tsc --noEmit",
    "validate": "npx tsx scripts/validate-env.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "npx tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "db:setup": "npm run prisma:generate && npm run prisma:push && npm run prisma:seed",
    "db:push:prod": "npx prisma db push --accept-data-loss",
    "postinstall": "prisma generate",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "health": "curl -s http://localhost:3000/api/health | npx json"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.2.1",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.85.1",
    "@types/bcryptjs": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.26.1",
    "lucide-react": "^0.553.0",
    "next": "^15.5.7",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.66.0",
    "recharts": "^2.15.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^14.0.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
