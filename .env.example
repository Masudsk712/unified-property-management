# MongoDB Atlas Connection
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/unified-property-management?retryWrites=true&w=majority"

# NextAuth Configuration
AUTH_SECRET="generate-a-random-secret-here"
AUTH_URL="http://localhost:3000"

# Next Auth Providers (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"